{
  "manifest_version": 3,
  "name": "Kalodata Cookie Viewer",
  "version": "1.0",
  "description": "Exibe os cookies do Kalodata para copiar facilmente",
  "permissions": ["cookies"],
  "host_permissions": [
    "https://www.kalodata.com/*",
    "https://kalodata.com/*",
    "https://clip.kalowave.com/*",
    "https://www.kaloclip.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
